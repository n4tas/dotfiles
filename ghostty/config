# Dynamic theme colors
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

# Font
font-family = "CaskaydiaMono Nerd Font"
font-style = Regular
font-size = 18

# Window
window-theme = ghostty
window-padding-x = 14
window-padding-y = 10
confirm-close-surface=false
resize-overlay = never
gtk-toolbar-style = flat

# Cursor styling
cursor-style = "bar"
cursor-style-blink = false

# Cursor styling + SSH session terminfo
# (all shell integration options must be passed together)
shell-integration-features = no-cursor,ssh-env

# Keyboard bindings

keybind = performable:ctrl+c=copy_to_clipboard
keybind = performable:ctrl+v=paste_from_clipboard
keybind = ctrl+j=scroll_page_down
keybind = ctrl+k=scroll_page_up
# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# background-opacity
background-opacity = 1

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll
